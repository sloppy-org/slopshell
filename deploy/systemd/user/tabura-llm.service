[Unit]
Description=Tabura Local Coordinator LLM (Qwen3.5 9B GGUF)
After=network.target

[Service]
Type=simple
WorkingDirectory=@@REPO_ROOT@@
Environment=HOME=%h
Environment=PATH=%h/.local/bin:/usr/local/bin:/usr/bin:/bin
Environment=TABURA_LLM_MODEL_DIR=%h/.local/share/tabura-llm/models
Environment=LLAMA_SERVER_BIN=@@LLAMA_SERVER_BIN@@
ExecStart=@@REPO_ROOT@@/scripts/setup-local-llm.sh
Restart=on-failure
RestartSec=5
TimeoutStopSec=15

[Install]
WantedBy=default.target
