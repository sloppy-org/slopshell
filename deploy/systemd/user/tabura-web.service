[Unit]
Description=Tabura Web UI
After=network.target tabura-codex-app-server.service tabura-piper-tts.service
Wants=tabura-codex-app-server.service tabura-piper-tts.service

[Service]
Type=simple
WorkingDirectory=@@REPO_ROOT@@
PassEnvironment=DISPLAY WAYLAND_DISPLAY XAUTHORITY XDG_RUNTIME_DIR DBUS_SESSION_BUS_ADDRESS
Environment=HOME=%h
Environment=SHELL=/usr/bin/bash
Environment=TABURA_APP_SERVER_MODEL=gpt-5.3-codex-spark
Environment=TABURA_INTENT_LLM_URL=@@TABURA_INTENT_LLM_URL@@
Environment=TABURA_INTENT_LLM_MODEL=qwen/qwen3.5-9b
Environment=TABURA_INTENT_LLM_PROFILE=qwen3.5-9b
Environment=TABURA_INTENT_LLM_PROFILE_OPTIONS=qwen3.5-9b,qwen3.5-4b
ExecStart=/usr/bin/bash -lc 'source ~/.bashrc >/dev/null 2>&1 || true; cd @@REPO_ROOT@@; exec /usr/bin/env go run ./cmd/tabura server --project-dir @@REPO_ROOT@@ --data-dir %h/.local/share/tabura-web --web-host @@TABURA_WEB_HOST@@ --web-port 8420 --mcp-host 127.0.0.1 --mcp-port 9420 --app-server-url ws://127.0.0.1:8787 --tts-url http://127.0.0.1:8424 --dev-runtime'
Restart=on-failure
RestartSec=2
TimeoutStopSec=5

[Install]
WantedBy=default.target
