[Unit]
Description=Tabura Web UI
After=network.target tabura-mcp.service tabura-codex-app-server.service tabura-voxtype-mcp.service
Wants=tabura-mcp.service tabura-codex-app-server.service tabura-voxtype-mcp.service

[Service]
Type=simple
WorkingDirectory=%h/code/assi/tabura
PassEnvironment=DISPLAY WAYLAND_DISPLAY XAUTHORITY XDG_RUNTIME_DIR DBUS_SESSION_BUS_ADDRESS
Environment=HOME=%h
Environment=SHELL=/usr/bin/bash
Environment=TABURA_APP_SERVER_MODEL=gpt-5.3-codex-spark
ExecStart=/usr/bin/bash -lc 'source ~/.bashrc >/dev/null 2>&1 || true; cd %h/code/assi/tabura; exec /usr/bin/env go run ./cmd/tabura web --project-dir %h/code/assi/tabura --data-dir %h/.local/share/tabura-web --host 0.0.0.0 --port 8420 --local-mcp-url http://127.0.0.1:9420/mcp --app-server-url ws://127.0.0.1:8787 --dev-runtime'
Restart=on-failure
RestartSec=2
TimeoutStopSec=5

[Install]
WantedBy=default.target
