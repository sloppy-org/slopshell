[Unit]
Description=Watch Tabura source for dev reload
After=tabura-codex-app-server.service tabura-web.service
Wants=tabura-codex-app-server.service tabura-web.service

[Service]
Type=simple
WorkingDirectory=%h/code/assi/tabula
ExecStart=%h/code/assi/tabula/scripts/tabura-dev-watch.sh
Restart=always
RestartSec=1

[Install]
WantedBy=default.target
